# ═══════════════════════════════════════════════════════════════
# AI Dungeon Master - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────
# Frontend URL (for CORS)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
# Generate a secure random string for production
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# AI Configuration (MiMo API - OpenAI Compatible)
# ─────────────────────────────────────────────
# Your MiMo API key or OpenAI API key
MIMO_API_KEY=your-mimo-api-key-here

# Alternative: Use OpenAI directly
# OPENAI_API_KEY=sk-your-openai-key

# API Base URL (MiMo endpoint or OpenAI)
MIMO_API_BASE_URL=https://api.openai.com/v1

# Model to use (gpt-4, gpt-3.5-turbo, or your MiMo model)
MIMO_MODEL=gpt-4

# ─────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────
# SQLite database path (relative to backend folder)
DB_PATH=./db/dungeon.db
