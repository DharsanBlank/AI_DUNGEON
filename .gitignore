# ═══════════════════════════════════════════════════════════════
# AI Dungeon Master - Git Ignore
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Environment Variables (NEVER COMMIT!)
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─────────────────────────────────────────────
# Build Outputs
# ─────────────────────────────────────────────
dist/
build/
*.tgz

# ─────────────────────────────────────────────
# Database Files
# ─────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm

# ─────────────────────────────────────────────
# IDE & Editor Files
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# OS Generated Files
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─────────────────────────────────────────────
# Debug Logs
# ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────
# Testing & Coverage
# ─────────────────────────────────────────────
coverage/
.nyc_output/

# ─────────────────────────────────────────────
# Temporary Files
# ─────────────────────────────────────────────
*.tmp
*.temp
.cache/

# ─────────────────────────────────────────────
# Kilo
# ─────────────────────────────────────────────
.kilo/
.continue/
